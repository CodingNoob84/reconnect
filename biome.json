{
	"$schema": "https://biomejs.dev/schemas/2.2.4/schema.json",

	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},

	"files": {
  "ignoreUnknown": false,
  "includes": [
    "**/src/**/*",
    "**/.vscode/**/*",
    "**/index.html",
    "**/vite.config.ts",
    "!**/src/routeTree.gen.ts",
    "!**/.tanstack",
    "!**/.tanstack/**",
    "!**/src/styles.css"
  ]
},

	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},

	"organizeImports": {
		"enabled": true
	},

	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},

	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedImports": "error"
			}
		}
	},

	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	}
}